generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model comments {
  comment_id     String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parent_id      String?    @db.Uuid
  user_id        String     @db.Uuid
  game_id        String     @db.Uuid
  comment        String
  is_deleted     Boolean?   @default(false)
  created_at     DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?  @default(now()) @db.Timestamptz(6)
  games          games      @relation(fields: [game_id], references: [game_id], onDelete: NoAction, onUpdate: NoAction)
  users          users      @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  comments       comments?  @relation("commentsTocomments", fields: [parent_id], references: [comment_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_parent")
  other_comments comments[] @relation("commentsTocomments")
}

model favorites {
  favorite_id String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String?   @db.Uuid
  game_id     String?   @db.Uuid
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  games       games?    @relation(fields: [game_id], references: [game_id], onDelete: NoAction, onUpdate: NoAction)
  users       users?    @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([user_id, game_id], map: "unique_fav")
}

model games {
  game_id       String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String          @unique @db.VarChar(255)
  description   String?         @db.VarChar(1023)
  author        String?         @db.Uuid
  game_link     String?
  main_image    String
  is_deleted    Boolean         @default(true)
  created_at    DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?       @default(now()) @db.Timestamptz(6)
  comments      comments[]
  favorites     favorites[]
  users         users?          @relation(fields: [author], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_gms")
  single_rating single_rating[]
  total_rating  total_rating?
}

model reports {
  report_id    String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  report_filer String          @db.Uuid
  remark       String?         @db.VarChar(512)
  category     report_category
  report_item  String          @db.Uuid
  is_resolved  Boolean?        @default(false)
  created_at   DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at   DateTime?       @default(now()) @db.Timestamptz(6)
  users        users           @relation(fields: [report_filer], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
}

model single_rating {
  rating_id  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  game_id    String    @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  rating     Int
  games      games     @relation(fields: [game_id], references: [game_id], onDelete: NoAction, onUpdate: NoAction)
  users      users     @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([user_id, game_id], map: "unique_rating")
}

model total_rating {
  game_id    String @id @db.Uuid
  one_star   Int?   @default(0)
  two_star   Int?   @default(0)
  three_star Int?   @default(0)
  four_star  Int?   @default(0)
  five_star  Int?   @default(0)
  games      games  @relation(fields: [game_id], references: [game_id], onDelete: NoAction, onUpdate: NoAction)
}

model users {
  user_id       String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username      String          @unique @db.VarChar(255)
  email         String          @unique @db.VarChar(255)
  hash          String?
  avatar        String?
  birth_date    DateTime        @db.Date
  gender        String?         @db.VarChar(1)
  role          role_type
  enabled       Boolean         @default(false)
  is_deleted    Boolean         @default(false)
  created_at    DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?       @default(now()) @db.Timestamptz(6)
  comments      comments[]
  favorites     favorites[]
  games         games[]
  reports       reports[]
  single_rating single_rating[]
}

enum report_category {
  user
  game
  comment
}

enum role_type {
  user
  admin
}
